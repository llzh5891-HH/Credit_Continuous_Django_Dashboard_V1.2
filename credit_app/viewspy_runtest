def load_relationship_data():
    """读取Relationship Level主数据表"""
    print(f"\n=== 加载 Relationship Level 数据 ===")
    if not os.path.exists(RELATIONSHIP_TABLE_PATH):
        print(f"❌ 文件不存在: {RELATIONSHIP_TABLE_PATH}")
        return []
    
    try:
        df = pd.read_csv(RELATIONSHIP_TABLE_PATH)
        print(f"✅ 成功读取，行数: {len(df)}, 列数: {len(df.columns)}")
        print(f"列名: {df.columns.tolist()}")
        return df.to_dict('records')
    except Exception as e:
        print(f"❌ 读取失败: {str(e)}")
        return []

