def run_tests(request):
    """执行所有测试并生成异常记录"""
    print("\n=== 执行测试 ===")
    
    # 加载数据
    relationship_data = load_relationship_data()
    customer_data = load_customer_data()
    
    # 打包数据供测试使用
    test_data = {
        'relationship': relationship_data,
        'customer': customer_data
    }
    
    # 获取所有测试并执行
    all_tests = TestRegistry.get_all_tests()
    all_exceptions = []
    
    for test in all_tests:
        print(f"执行测试: {test.test_id} - {test.test_name}")
        try:
            exceptions = test.execute(test_data)
            all_exceptions.extend(exceptions)
            print(f"  ✓ 完成，发现异常: {len(exceptions)} 条")
        except Exception as e:
            print(f"  ✗ 执行失败: {str(e)}")
    
    print(f"\n测试完成，共发现 {len(all_exceptions)} 条异常")
    
    # 保存异常到数据库
    save_exceptions(all_exceptions)
    
    return JsonResponse({
        'success': True,
        'total_tests': len(all_tests),
        'total_exceptions': len(all_exceptions)
    })

def save_exceptions(exceptions):
    """保存异常记录到数据库"""
    for exc in exceptions:
        ExceptionRecord.objects.create(
            test_id=exc['test_id'],
            test_name=exc['test_name'],
            category=exc['category'],
            severity=exc['severity'],
            record_id=exc['record_id'],
            field_name=exc.get('field_name', ''),
            actual_value=exc.get('actual_value'),
            expected_value=exc.get('expected_value'),
            description=exc['description']
        )

