# ==================== 测试注册器 ====================

class TestRegistry:
    """测试注册器 - 管理所有测试类"""
    
    @staticmethod
    def get_all_tests():
        """获取所有测试实例"""
        tests = []
        
        # Credit Origination
        tests.append(CreditOriginationTests.ApplicationAmountThresholdTest())
        tests.append(CreditOriginationTests.QuickApprovalTest())
        tests.append(CreditOriginationTests.CustomerRiskScoreTest())
        tests.append(CreditOriginationTests.DocumentCompletenessTest())
        
        # Credit Facility Creation
        tests.append(CreditFacilityCreationTests.FacilityLimitExceedTest())
        tests.append(CreditFacilityCreationTests.FacilityTypeValidationTest())
        tests.append(CreditFacilityCreationTests.InterestRateCheckTest())
        tests.append(CreditFacilityCreationTests.ExpiryDateValidationTest())
        
        # Credit Facility Management
        tests.append(CreditFacilityManagementTests.HighUtilizationTest())
        tests.append(CreditFacilityManagementTests.ExpiryWarningTest())
        tests.append(CreditFacilityManagementTests.StatusChangeAuditTest())
        tests.append(CreditFacilityManagementTests.BalanceAccuracyTest())
        
        # Credit Oversight & Governance
        tests.append(CreditOversightGovernanceTests.ConcentrationRiskTest())
        tests.append(CreditOversightGovernanceTests.PolicyComplianceTest())
        tests.append(CreditOversightGovernanceTests.AuditTrailIntegrityTest())
        tests.append(CreditOversightGovernanceTests.DataQualityValidationTest())
        
        return tests
    
    @staticmethod
    def get_tests_by_category(category):
        """按类别获取测试"""
        all_tests = TestRegistry.get_all_tests()
        return [t for t in all_tests if t.category == category]
    
    @staticmethod
    def get_test_by_id(test_id):
        """按ID获取测试"""
        all_tests = TestRegistry.get_all_tests()
        for test in all_tests:
            if test.test_id == test_id:
                return test
        return None
