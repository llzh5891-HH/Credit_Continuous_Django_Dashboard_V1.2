from abc import ABC, abstractmethod
from datetime import datetime

class BaseTest(ABC):
    """测试基类"""
    test_id = None
    test_name = None
    category = None
    severity = None
    description = None
    
    def __init__(self):
        assert self.test_id, "test_id must be defined"
        assert self.test_name, "test_name must be defined"
        assert self.category, "category must be defined"
        assert self.severity in ['critical', 'high', 'medium', 'low'], "Invalid severity"
    
    @abstractmethod
    def execute(self, data):
        """执行测试，返回异常列表"""
        pass
    
    def create_exception(self, record_id, field_name, actual_value, expected_value=None, description=None):
        """创建异常记录"""
        return {
            'test_id': self.test_id,
            'test_name': self.test_name,
            'category': self.category,
            'severity': self.severity,
            'record_id': record_id,
            'field_name': field_name,
            'actual_value': str(actual_value),
            'expected_value': str(expected_value) if expected_value else None,
            'description': description or f"Test {self.test_id} failed for record {record_id}",
            'created_at': datetime.now().isoformat()
        }


